# SDLC Validation Gate Rules for Codex CLI
#
# Prompts before git commit to remind about validation gates.
# Install: copy to ~/.codex/rules/ or add to project .codex/rules/
#
# Test with:
#   codex execpolicy check --pretty --rules rules/sdlc.rules -- git commit -m "test"

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "SDLC validation gates: run build, tests, and lint before committing. Use /prompts:commit for a guided commit with all gates.",
    match = [
        "git commit -m 'feat: add auth'",
        "git commit --amend",
        "git commit -a -m 'fix: typo'",
    ],
    not_match = [
        "git status",
        "git diff --staged",
        "git log --oneline",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force-pushing is forbidden. Use --force-with-lease if you must overwrite remote history.",
    match = [
        "git push --force origin main",
    ],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset discards uncommitted changes. Make sure you have no unsaved work.",
    match = [
        "git reset --hard HEAD~1",
        "git reset --hard origin/main",
    ],
)
